#!/usr/bin/env bash
# ============================================================
# HealthOS Pre-Commit Hook
# ============================================================
# Prevents accidental commits of secrets, credentials, and
# large binary files. Runs in every branch and worktree.
#
# Install: git config core.hooksPath .githooks
# ============================================================

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

BLOCKED=0

# --------------------------------------------------------
# 1. Check for secret patterns in staged files
# --------------------------------------------------------
SECRET_PATTERNS=(
    'SUPABASE_URL=https://'
    'SUPABASE_ANON_KEY='
    'SUPABASE_SERVICE_ROLE_KEY='
    'sk-[a-zA-Z0-9]{20,}'
    'anthropic_api_key'
    'ANTHROPIC_API_KEY='
    'Bearer [a-zA-Z0-9_\-\.]{20,}'
    'password\s*=\s*["\x27][^"\x27]{4,}'
    'secret\s*=\s*["\x27][^"\x27]{4,}'
)

# Files excluded from secret scanning (infrastructure files that
# reference secret patterns as search strings, not actual secrets)
EXCLUDED_FROM_SECRET_SCAN=(
    '.githooks/'
    '.claude/'
    'docs/'
    '*.xcconfig.template'
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)

# Filter out excluded paths for secret scanning
SCANNABLE_FILES=""
if [ -n "$STAGED_FILES" ]; then
    for file in $STAGED_FILES; do
        EXCLUDED=0
        for exclude_pattern in "${EXCLUDED_FROM_SECRET_SCAN[@]}"; do
            if [[ "$file" == $exclude_pattern* ]] || [[ "$file" == $exclude_pattern ]]; then
                EXCLUDED=1
                break
            fi
        done
        if [ "$EXCLUDED" -eq 0 ]; then
            SCANNABLE_FILES="$SCANNABLE_FILES $file"
        fi
    done
fi

if [ -n "$SCANNABLE_FILES" ]; then
    for pattern in "${SECRET_PATTERNS[@]}"; do
        MATCHES=$(echo "$SCANNABLE_FILES" | xargs grep -lEi "$pattern" 2>/dev/null || true)
        if [ -n "$MATCHES" ]; then
            echo -e "${RED}BLOCKED: Possible secret detected matching pattern: ${pattern}${NC}"
            echo "$MATCHES" | while read -r file; do
                echo "  → $file"
            done
            BLOCKED=1
        fi
    done
fi

# --------------------------------------------------------
# 2. Block commits of sensitive file types
# --------------------------------------------------------
BLOCKED_EXTENSIONS=('.env' '.p8' '.pem' '.key' '.pfx')
BLOCKED_FILENAMES=('.env' '.env.local' '.env.production' '.env.staging')

for file in $STAGED_FILES; do
    filename=$(basename "$file")
    extension=".${filename##*.}"

    # Block sensitive extensions
    for blocked_ext in "${BLOCKED_EXTENSIONS[@]}"; do
        if [ "$extension" = "$blocked_ext" ]; then
            echo -e "${RED}BLOCKED: Sensitive file type committed: ${file}${NC}"
            BLOCKED=1
        fi
    done

    # Block sensitive filenames
    for blocked_name in "${BLOCKED_FILENAMES[@]}"; do
        if [ "$filename" = "$blocked_name" ]; then
            echo -e "${RED}BLOCKED: Sensitive file committed: ${file}${NC}"
            BLOCKED=1
        fi
    done

    # Block .xcconfig files (unless they are templates)
    if [[ "$file" == *.xcconfig ]] && [[ "$file" != *.xcconfig.template ]]; then
        echo -e "${RED}BLOCKED: Real xcconfig file committed (use .xcconfig.template instead): ${file}${NC}"
        BLOCKED=1
    fi
done

# --------------------------------------------------------
# 3. Block large files (> 5MB)
# --------------------------------------------------------
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        FILE_SIZE=$(wc -c < "$file" | tr -d ' ')
        MAX_SIZE=5242880  # 5MB
        if [ "$FILE_SIZE" -gt "$MAX_SIZE" ]; then
            SIZE_MB=$((FILE_SIZE / 1048576))
            echo -e "${RED}BLOCKED: File too large (${SIZE_MB}MB > 5MB): ${file}${NC}"
            BLOCKED=1
        fi
    fi
done

# --------------------------------------------------------
# Result
# --------------------------------------------------------
if [ "$BLOCKED" -eq 1 ]; then
    echo ""
    echo -e "${RED}Commit blocked. Fix the issues above and try again.${NC}"
    echo "If you believe this is a false positive, review .githooks/pre-commit."
    exit 1
fi

exit 0
